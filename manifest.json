{
  "manifest_version": 3,
  "name": "Gemini - OpenRouter Voice",
  "version": "1.0",
  "description": "Intégration vocale native pour Gemini via OpenRouter",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "declarativeNetRequest"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://openrouter.ai/*",
    "https://gemini.google.com/*",
    "https://api.mistral.ai/*",
    "wss://api.mistral.ai/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["processor.js"],
      "matches": ["https://gemini.google.com/*"]
    }
  ]
}